# Environment Configuration Example
# Copy to .env and customize for your environment

# Application settings
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://continumm:continumm@localhost:5432/continumm

# Telemetry
TELEMETRY_ENABLED=false
SCAN_SUBNETS=192.168.1.0/24
DISCOVERY_INTERVAL_SECONDS=300
POLL_INTERVAL_SECONDS=30
PORT_SCAN_ENABLED=false
PORT_SCAN_TOP_PORTS=50
PORT_SCAN_LIMIT=25
SCAN_USE_ARP=true
SCAN_USE_SCAPY=false
SCAN_USE_NMAP=true

# Alerting
ALERT_OFFLINE_AFTER=3
ALERT_LATENCY_MS=200
ALERT_PACKET_LOSS_PERCENT=20

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=continumm-backend

# Git commit (set automatically during build)
# GIT_COMMIT=<populated-during-build>
